{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ella",
  "scopeName": "source.ella",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#service"
    },
    {
      "include": "#model"
    },
    {
      "include": "#enum"
    },
    {
      "include": "#error"
    },
    {
      "include": "#const"
    },
    {
      "include": "#primitives"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.ella",
          "match": "#.*$"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.ella",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ella",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.ella",
              "begin": "\\{\\{",
              "end": "\\}\\}",
              "patterns": [
                {
                  "name": "variable.parameter.interpolation.ella",
                  "match": "[A-Za-z_][A-Za-z0-9_]*"
                }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.unit.ella",
          "match": "\\b-?(?:0|[1-9][0-9]*)(?:kb|mb|gb|tb|eb|ms|s|m|h)\\b"
        },
        {
          "name": "constant.numeric.ella",
          "match": "\\b-?(?:0|[1-9][0-9]*)\\b"
        }
      ]
    },
    "primitives": {
      "patterns": [
        {
          "name": "storage.type.primitive.ella",
          "match": "\\b(?:string|bool|byte|int8|int16|int32|int64|uint8|uint16|uint32|uint64|float32|float64|timestamp|timestamps|any)\\b"
        },
        {
          "name": "storage.type.collection.ella",
          "match": "\\bmap\\b"
        },
        {
          "name": "keyword.operator.array.ella",
          "match": "\\[\\]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.error.ella",
          "match": "\\bErr[A-Za-z0-9_]*\\b"
        },
        {
          "name": "support.type.named.ella",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.ella",
          "match": "=>"
        },
        {
          "name": "keyword.operator.assignment.ella",
          "match": "=(?!>)"
        },
        {
          "name": "keyword.operator.type.ella",
          "match": ":"
        },
        {
          "name": "keyword.operator.spread.ella",
          "match": "\\.\\.\\."
        },
        {
          "name": "punctuation.separator.comma.ella",
          "match": ","
        },
        {
          "name": "punctuation.section.braces.begin.ella",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.ella",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.ella",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.ella",
          "match": "\\)"
        },
        {
          "name": "punctuation.definition.type.begin.ella",
          "match": "<"
        },
        {
          "name": "punctuation.definition.type.end.ella",
          "match": "(?<!=)>"
        }
      ]
    },
    "const": {
      "patterns": [
        {
          "name": "meta.definition.constant.ella",
          "begin": "^(\\s*)(const)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "beginCaptures": {
            "2": {
              "name": "keyword.declaration.constant.ella"
            },
            "3": {
              "name": "variable.other.constant.ella"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#numbers"
            },
            {
              "include": "#string"
            },
            {
              "include": "#operators"
            }
          ]
        }
      ]
    },
    "enum": {
      "patterns": [
        {
          "name": "meta.definition.enum.ella",
          "begin": "^(\\s*)(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\{)",
          "beginCaptures": {
            "2": {
              "name": "keyword.declaration.enum.ella"
            },
            "3": {
              "name": "entity.name.type.enum.ella"
            },
            "4": {
              "name": "punctuation.section.braces.begin.ella"
            }
          },
          "end": "^(\\s*)(\\})",
          "endCaptures": {
            "2": {
              "name": "punctuation.section.braces.end.ella"
            }
          },
          "patterns": [
            {
              "name": "variable.other.enummember.ella",
              "match": "^(\\s*)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*(?:=|$))"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#string"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "model": {
      "patterns": [
        {
          "name": "meta.definition.model.ella",
          "begin": "^(\\s*)(model)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\{)",
          "beginCaptures": {
            "2": {
              "name": "keyword.declaration.model.ella"
            },
            "3": {
              "name": "entity.name.type.model.ella"
            },
            "4": {
              "name": "punctuation.section.braces.begin.ella"
            }
          },
          "end": "^(\\s*)(\\})",
          "endCaptures": {
            "2": {
              "name": "punctuation.section.braces.end.ella"
            }
          },
          "patterns": [
            {
              "name": "meta.model.spread.ella",
              "match": "^(\\s*)(\\.\\.\\.)([A-Za-z_][A-Za-z0-9_]*)",
              "captures": {
                "2": {
                  "name": "keyword.operator.spread.ella"
                },
                "3": {
                  "name": "support.type.named.ella"
                }
              }
            },
            {
              "name": "meta.model.field.ella",
              "begin": "^(\\s*)([A-Za-z_][A-Za-z0-9_]*)(\\s*:)",
              "beginCaptures": {
                "2": {
                  "name": "variable.other.member.ella"
                },
                "3": {
                  "name": "keyword.operator.type.ella"
                }
              },
              "end": "$",
              "patterns": [
                {
                  "include": "#primitives"
                },
                {
                  "include": "#identifiers"
                },
                {
                  "include": "#operators"
                },
                {
                  "include": "#comments"
                }
              ]
            },
            {
              "include": "#primitives"
            },
            {
              "include": "#identifiers"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "service": {
      "patterns": [
        {
          "name": "meta.definition.service.ella",
          "begin": "^(\\s*)(service)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\{)",
          "beginCaptures": {
            "2": {
              "name": "keyword.declaration.service.ella"
            },
            "3": {
              "name": "entity.name.type.service.ella"
            },
            "4": {
              "name": "punctuation.section.braces.begin.ella"
            }
          },
          "end": "^(\\s*)(\\})",
          "endCaptures": {
            "2": {
              "name": "punctuation.section.braces.end.ella"
            }
          },
          "patterns": [
            {
              "name": "meta.service.method.ella",
              "begin": "^(\\s*)([A-Za-z_][A-Za-z0-9_]*)(\\s*)(\\()",
              "beginCaptures": {
                "2": {
                  "name": "entity.name.function.service.ella"
                },
                "4": {
                  "name": "punctuation.section.parens.begin.ella"
                }
              },
              "end": "$",
              "patterns": [
                {
                  "name": "variable.parameter.ella",
                  "match": "\\b[a-z][A-Za-z0-9_]*\\b(?=\\s*:)"
                },
                {
                  "name": "entity.name.function.service.ella",
                  "match": "=>"
                },
                {
                  "include": "#primitives"
                },
                {
                  "include": "#identifiers"
                },
                {
                  "include": "#operators"
                }
              ]
            },
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "error": {
      "patterns": [
        {
          "name": "meta.definition.error.ella",
          "begin": "^(\\s*)(error)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\{)",
          "beginCaptures": {
            "2": {
              "name": "keyword.declaration.error.ella"
            },
            "3": {
              "name": "entity.name.type.error.ella"
            },
            "4": {
              "name": "punctuation.section.braces.begin.ella"
            }
          },
          "end": "\\}",
          "patterns": [
            {
              "name": "variable.other.member.error.ella",
              "match": "\\b(?:Code|Msg)\\b"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#string"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#comments"
            }
          ]
        }
      ]
    }
  }
}
